# MeterFlow Backend Environment Variables

# Server
PORT=5000
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=supersecretkey_supersecretkey_supersecretkey_supersecretkey
REFRESH_TOKEN_SECRET=superrefresh_superrefresh_superrefresh_superrefresh

# MongoDB
MONGODB_URI=mongodb://localhost:27017/meterflow

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# BullMQ Queue (optional)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGIN=http://localhost:3000
